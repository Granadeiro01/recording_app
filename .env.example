# Copy this file to .env and fill in local values as needed.
# This file documents all supported local secrets and runtime settings.

# Core runtime paths
INPUT_DIR=./input
OUTPUT_DIR=./output

# Groq transcription runtime
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3

# LLM / API credentials
GROQ_API_KEY=replace_me

# Telegram integration
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me
TELEGRAM_API_ID=replace_me
TELEGRAM_API_HASH=replace_me
TELEGRAM_PHONE_NUMBER=replace_me
TELEGRAM_SESSION_STRING=replace_me
